#This script looks like:
        #!/bin/bash

        #For use with a single fasta file containing peptide data

        SEQ=$1

        blastp -db ArachnoServer_pep_db -evalue 1e-20 \
         -outfmt "6 qseqid sseqid pident length evalue mismatch gapopen qstart qend sstart send qlen slen" -query $SEQ \
         -max_target_seqs 1 -num_threads 1 -out $SEQ\.blastp.ArachnoServer_pep_db.out
#end script 

